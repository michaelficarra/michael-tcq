# Server
PORT=3000
SESSION_SECRET=replace-with-a-random-string

# Comma-separated GitHub usernames who have admin access
# ADMIN_USERNAMES=admin

# GitHub OAuth (create an app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Persistence: "file" for local development, "firestore" for production
STORE=file

# GCP (only needed when STORE=firestore or when deploying)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Set this if your Firestore database is not the default "(default)" database
# FIRESTORE_DATABASE_ID=mtcq-db

# --- Production deployment (used by scripts/deploy.sh) ---
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# GCP_SERVICE_ACCOUNT=
# CLOUD_RUN_SERVICE=tcq
# PROD_GITHUB_CLIENT_ID=
# PROD_GITHUB_CLIENT_SECRET=
# PROD_GITHUB_CALLBACK_URL=https://<cloud-run-url>/auth/github/callback
# Generate with: head -c 32 /dev/urandom | base64 | tr -d '=/+' | head -c 40
# PROD_SESSION_SECRET=
