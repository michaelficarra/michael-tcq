# Server
PORT=3000
SESSION_SECRET=replace-with-a-random-string

# GitHub OAuth (create an app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Persistence: "file" for local development, "firestore" for production
STORE=file

# GCP (only needed when STORE=firestore)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
