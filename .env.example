# Environment-specific configuration
#
# The server loads .env.development or .env.production based on NODE_ENV.
# Create the appropriate file for your environment:
#
#   Development: .env.development (committed — no secrets)
#   Production:  .env.production  (gitignored — contains secrets)
#
# See below for the available fields.

PORT=3000
# Generate with: head -c 32 /dev/urandom | base64 | tr -d '=/+' | head -c 40
SESSION_SECRET=replace-with-a-random-string

# Comma-separated admin users. Each entry is either a bare GitHub username
# (e.g. admin) or a provider-qualified id (e.g. github:12345, google:1057…,
# orcid:0000-0002-1825-0097). The premium-tier list (managed at runtime via
# the Admin tab) accepts the same two forms.
# ADMIN_USERNAMES=admin

# Premium-tier membership is no longer configured here. Admins manage the
# premium-user list at runtime via the Admin tab of the home page; the
# list is persisted in the app-settings store (single JSON file in
# .data/app-settings.json for local dev, single Firestore doc at
# `app-settings/singleton` in production).

# Authentication providers. The server supports multiple OAuth providers at
# once; each is enabled simply by setting its credentials. When NONE are set
# AND NODE_ENV is not "production", the server runs in mock auth mode for
# development. In production, mock auth is disabled — a deploy with no provider
# configured fails closed (no login) rather than auto-logging everyone in as an
# admin. The login page shows one button per configured provider.
#
# Callback URLs are derived per provider as ${OAUTH_CALLBACK_BASE_URL}/<id>/callback
# (e.g. http://localhost:3000/auth/github/callback). Override the base if the
# server isn't reachable at http://localhost:3000/auth.
# OAUTH_CALLBACK_BASE_URL=http://localhost:3000/auth

# GitHub (create an app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ORCID (register a public-API client in your ORCID account → Developer tools).
# For local testing, register a SANDBOX client and point ORCID_BASE_URL at the
# sandbox; leave ORCID_BASE_URL unset for production (defaults to orcid.org).
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
# ORCID_BASE_URL=https://sandbox.orcid.org

# Future providers slot in the same way once implemented, e.g.:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Persistence: "file" for local development, "firestore" for production
STORE=file

# GCP (only needed when STORE=firestore or when deploying)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Set this if your Firestore database is not the default "(default)" database
# FIRESTORE_DATABASE_ID=mtcq-db

# --- Deployment (used by scripts/deploy.sh, read from .env.production) ---
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# GCP_SERVICE_ACCOUNT=
# CLOUD_RUN_SERVICE=tcq
